# Zkopíruj jako .env na vm-twopmoment a vyplň.
# .env NIKDY necommituj.

# Doména, na které API poslouchá. Musí mít A záznam na IP té VM,
# jinak Caddy nedostane certifikát.
API_DOMAIN=api.2pmoment.cz

# Mail pro Let's Encrypt (upozornění na expiraci certifikátu).
ACME_EMAIL=stanislav.kasika@gmail.com

# Origins frontendů na Netlify, oddělené čárkou. Bez lomítka na konci.
CORS_ORIGINS=https://pekarna.2pmoment.cz,http://localhost:5173

# Postgres. Heslo vygeneruj náhodné, např. `openssl rand -base64 32`.
POSTGRES_USER=twopmoment
POSTGRES_PASSWORD=
POSTGRES_DB=twopmoment

# Kolik poptávek smí jedna IP odeslat za hodinu.
INQUIRY_RATE_MAX=5
